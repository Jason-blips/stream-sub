{
  "manifest_version": 3,
  "name": "会议实时翻译字幕",
  "version": "0.1.0",
  "description": "为 Zoom、Teams 等会议提供实时多语言字幕",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8765/*",
    "ws://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
